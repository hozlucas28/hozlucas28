{
	"service": "devcontainer",
	"dockerComposeFile": "compose.yaml",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "latest",
			"pnpmVersion": "latest"
		},
		"ghcr.io/devcontainers-extra/features/uv:1": {
			"version": "latest"
		}
	},
	"remoteUser": "root",
	"onCreateCommand": "chmod +x .devcontainer/setup-tools.sh",
	"postCreateCommand": ".devcontainer/setup-tools.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot-chat",
				"redhat.vscode-yaml",
				"bierner.markdown-checkbox",
				"bierner.markdown-preview-github-styles",
				"streetsidesoftware.code-spell-checker",
				"streetsidesoftware.code-spell-checker-spanish",
				"esbenp.prettier-vscode",
				"oxc.oxc-vscode",
				"EditorConfig.EditorConfig"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "oxc.oxc-vscode",
				"telemetry.telemetryLevel": "off",
				"telemetry.feedback.enabled": false,
				"files.exclude": {
					"**/.DS_Store": false,
					"**/.git": false,
					"**/.hg": false,
					"**/.svn": false,
					"**/Thumbs.db": false,
					".pnpm-store": true,
					"node_modules": true,
					"package.json": true,
					"pnpm-lock.yaml": true
				},
				"search.exclude": {
					"**/.DS_Store": true,
					"**/.git": true,
					"**/.hg": true,
					"**/.svn": true,
					"**/Thumbs.db": true,
					"**/node_modules": true,
					"**/bower_components": true,
					"**/*.code-search": true,
					".pnpm-store": true,
					"package.json": true,
					"pnpm-lock.yaml": true
				},
				"oxc.fmt.configPath": ".oxfmtrc.json",
				"yaml.schemas": {
					"https://raw.githubusercontent.com/docker/vscode-extension/6a88caada42b57090df7ce91ec2a6561b422afe1/misc/empty.json": [
						".github/workflows/*.yaml"
					],
					"https://raw.githubusercontent.com/rendercv/rendercv/refs/tags/v2.6/schema.json": ["resumes/*.yaml"]
				}
			}
		}
	}
}
