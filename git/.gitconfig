[core]
    editor = code --wait
    fsmonitor = true
    whitespace = fix,-indent-with-non-tab,trailing-space,space-before-tab
    untrackedCache = true

[init]
    defaultBranch = main

[user]
    name = hozlucas28
    email = hozlucas28@gmail.com
    signingkey = ~/.ssh/id_ed25519.pub

[gpg]
	format = ssh

[tag]
	gpgSign = true

[commit]
    gpgsign = true

[pull]
    rebase = true

[push]
    default = simple
    followTags = true
    autoSetupRemote = true

[fetch]
    prune = true
    pruneTags = true

[diff]
    tool = code
    renames = true
    algorithm = histogram
    colorMoved = default

[difftool]
    prompt = false

[difftool "code"]
    cmd = code --wait --diff \"$LOCAL\" \"$REMOTE\"

[merge]
    tool = code
    conflictstyle = zdiff3

[mergetool]
    prompt = false
    keepBackup = false

[mergetool "code"]
    cmd = code --wait --merge \"$REMOTE\" \"$LOCAL\" \"$BASE\" \"$MERGED\"

[rebase]
    autoStash = true
    autoSquash = true
    updateRefs = true

[rerere]
    enabled = true
    autoUpdate = true

[help]
    autocorrect = prompt

[color]
    ui = auto

[alias]
    undo = reset --soft HEAD~1
    graph = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
    branches = branch --sort=-committerdate --format='%(HEAD) %(color:bold yellow)%(refname:short)%(color:reset) - %(color:bold green)(%(committerdate:relative))%(color:reset) %(color:dim white)%(authorname)%(color:reset)'
    show-sha = "!f() { gh browse \"${1:-$(git rev-parse HEAD)}\"; }; f"
    find-commit = log --grep
    last-commit = log -1 HEAD --stat
    contributors = "!git log --no-merges --format='%aE|%aN' | awk -F'|' '{c[$1]++; if(!n[$1]) n[$1]=$2} END {for(e in c) print c[e] \"|\" n[e] \"|\" e}' | sort -t'|' -k1,1nr | awk -F'|' '{printf \"\\033[1;32m%-6s\\033[0m commits - \\033[1;33m%s\\033[0m \\033[2;30m<%s>\\033[0m\\n\", $1, $2, $3}'"
    find-code-change = log -S
    add-to-last-commit = commit --amend --no-edit

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[include]
    path = ~/.gitconfig.local
